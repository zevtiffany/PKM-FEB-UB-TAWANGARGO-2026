// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model InfoDesa {
  id             Int      @id @default(1)
  nama           String   @default("Desa Tawangargo")
  kecamatan      String   @default("Kecamatan Karangploso")
  kabupaten      String   @default("Kabupaten Malang")
  deskripsi      String
  jumlahDusun    Int      @default(6)
  namaaDusun     String   @default("Suwaluhan, Kalimalang, Leban, Ngudi, Lasah, Boro")
  jumlahPenduduk Int      @default(10211)
  mayoritas      String   @default("Petani & Perkebunan (57%)")
  komoditas      String   @default("Sawi, Kol, Brokoli, Tomat, Seledri, Cabai, Jagung")
  dikenal        String   @default("Desa Wisata Sayur Mayur Lereng Gunung Arjuno")
  emailKontak    String   @default("kkntawangargo@example.com")
  waKontak       String   @default("+6281234567890")
  periodeMulai   DateTime @default(now())
  periodeSelesai DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Kegiatan {
  id        Int      @id @default(autoincrement())
  judul     String
  tanggal   DateTime
  deskripsi String
  kategori  String
  foto      Foto[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Foto {
  id         Int      @id @default(autoincrement())
  url        String
  keterangan String?
  kegiatan   Kegiatan @relation(fields: [kegiatanId], references: [id], onDelete: Cascade)
  kegiatanId Int
}

model Anggota {
  id        Int      @id @default(autoincrement())
  nama      String
  peran     String
  foto      String?
  kontak    String?
  urutan    Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
