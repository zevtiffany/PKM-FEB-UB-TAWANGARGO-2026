# Credentials Admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ganti_password_anda
SESSION_SECRET=string_acak_minimal_32_karakter_isi_random

# Firebase Admin SDK
# Dapatkan dari: Firebase Console > Project Settings > Service Accounts > Generate new private key
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nXXXXX\n-----END PRIVATE KEY-----\n"

# Firebase Storage Bucket
# Format: your-project-id.appspot.com (atau your-project-id.firebasestorage.app untuk project baru)
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
